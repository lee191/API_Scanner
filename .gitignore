# Ignore everything by default, then explicitly allow source and docs.
*

# Repository metadata and documentation.
!/.gitignore
!/README.md
!/LICENSE
!/.github/
!/.github/workflows/
!/.github/workflows/*.yml

# Application source.
!/pyproject.toml
!/app.py
!/route_api_discovery.py
!/route_api_discovery_ctk.py
!/route_api_discovery_qt.py
!/GUI/
!/GUI/__init__.py
!/GUI/launcher.py

# Unit tests.
!/tests/
!/tests/*.py
!/tests/fixtures/
!/tests/fixtures/**


# Generated files, local environments, and sample scan outputs stay ignored.
__pycache__/
**/__pycache__/
*.py[cod]

# Virtual environments
/.venv/
/venv/
/env/

# Build & packaging artifacts
*.egg-info/
/dist/
/build/
*.egg

# Tool caches
/.pytest_cache/
/.ruff_cache/
/.mypy_cache/
/.coverage
/htmlcov/

# Claude Code worktrees & session data
/.claude/worktrees/
/.claude/session-data/

# Scan output files
/mag/
/discovery-result.*
/mycsat.*
*.xlsx
*.html
!/tests/fixtures/
!/tests/fixtures/**

# Temporary / OS files
*.tmp
*.log
_tmp_*
.DS_Store
Thumbs.db

# Reference images
*.png
*.jpg
